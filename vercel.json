{
  "build": {
    "env": {
      "CI": "false"
    }
  },
  "nodeVersion": "20.x",
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "http://161.118.238.100:8080/api/:path*"
    },
    {
      "source": "/((?!api/proxy).*)",
      "destination": "/index.html"
    }
  ]
}
