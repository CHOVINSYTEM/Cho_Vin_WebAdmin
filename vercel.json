{
  "build": {
    "env": {
      "CI": "false"
    }
  },
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "http://161.118.238.100:8080/api/:path*"
    },
    {
      "source": "/swagger/:path*",
      "destination": "http://161.118.238.100:8080/swagger/:path*"
    },
    {
      "source": "/((?!api/proxy|swagger).*)",
      "destination": "/index.html"
    }
  ]
}
